# Production site (Vercel custom domain). Used for metadataBase / canonical URLs.
NEXT_PUBLIC_SITE_URL=https://saferoute.sishutirtha.co.in

# Supabase (required for the app to work — add the same keys in Vercel → Project → Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use either the publishable key name or the classic anon key name (same value from Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Android/Capacitor: WebView loads this URL (same data as the website). Override when using a staging domain.
# CAPACITOR_SERVER_URL=https://saferoute.sishutirtha.co.in
# LAN dev only — if set, overrides production URL until you unset and run: npm run android:bundle
# CAPACITOR_LIVE_RELOAD_URL=http://192.168.1.x:8080
