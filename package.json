{
  "name": "safe-route",
  "private": true,
  "version": "0.0.0",
  "description": "Vercel: connect repo, set NEXT_PUBLIC_SITE_URL=https://saferoute.sishutirtha.co.in, deploy (next build). Android APK: capacitor loads that URL; run npm run cap:assets:android after changing resources/app-icon.svg, then npm run android:bundle. Icons: npm run icons:generate.",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\"",
    "dev:reset": "npm run clean && next dev -p 3000",
    "dev": "next dev -p 3000",
    "dev:8080": "next dev -p 8080",
    "dev:turbo": "next dev -p 3000 --turbo",
    "dev:lan": "next dev -p 3000 -H 0.0.0.0",
    "dev:lan:https": "next dev -p 3000 -H 0.0.0.0 --experimental-https",
    "dev:fresh": "npm run clean && next dev -p 3000",
    "build": "next build",
    "build:static": "cross-env NEXT_STATIC_EXPORT=1 next build",
    "start": "next start -p 3000",
    "start:8080": "next start -p 8080",
    "preview:static": "npx --yes serve@14 out -p 3000",
    "preview:static:8080": "npx --yes serve@14 out -p 8080",
    "lint": "eslint .",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "icons:generate": "node scripts/generate-brand-assets.mjs",
    "cap:assets:android": "npm run icons:generate && npx capacitor-assets generate --android",
    "android:bundle": "npm run build:static && npx cap sync android",
    "android:open": "npm run android:bundle && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.1",
    "@capacitor/camera": "^7.0.1",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/device": "^7.0.1",
    "@capacitor/geolocation": "^7.1.4",
